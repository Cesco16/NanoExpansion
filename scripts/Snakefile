		expand(path+"{sample}/nanoexpansion/"+"{sample}-straglr.vcf", sample=config["sample"]),
		expand(path+"{sample}/nanoexpansion/"+"{sample}-straglr.tsv", sample=config["sample"]),
		expand(path+"{sample}/nanoexpansion/"+"native{sample}_str_regions.bam", sample=config["sample"]),
		expand(path+"{sample}/nanoexpansion/"+"native{sample}_str_reads.bam", sample=config["sample"]),
		expand(path+"{sample}/nanoexpansion/"+"{sample}_straglr_annot.vcf", sample=config["sample"]),
		expand(path+"{sample}/nanoexpansion/"+"native{sample}_rep_annot.tsv", sample=config["sample"]),
		expand(path+"{sample}/nanoexpansion/"+"native{sample}_rep_plot.tsv", sample=config["sample"]),
		expand(path+"{sample}/nanoexpansion/{sample}_{disease}_{gene}.txt", sample=config["sample"], disease=config["disease"], gene=config["gene"])

