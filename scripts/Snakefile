rule tsv_to_vcf:
	input:
		tsv=path+"{sample}/nanoexpansion/"+"{sample}-straglr_old.tsv",
		bed=path+"{sample}/nanoexpansion/"+"{sample}-straglr.bed"
	output:
		vcf=path+"{sample}/nanoexpansion/"+"{sample}-straglr.vcf"
	params:
		gene=lambda wildcards: config["gene"]
	log:
		"logs/vcf/{sample}.log"
	message: ">> {wildcards.sample} : creating straglr vcf file"
	shell:
		"python create_vcf_file.py --tsv {input.tsv} --bed {input.bed} --vcf {output.vcf} --gene {params.gene}"

rule transform_tsv:
	input:
		tsv=path+"{sample}/nanoexpansion/"+"{sample}-straglr_old.tsv"
	output:
		tsv_t=path+"{sample}/nanoexpansion/"+"{sample}-straglr.tsv"
	log:
		"logs/tsv/{sample}.log"
	message: ">> {wildcards.sample} : transforming straglr tsv file"
	shell:
		"python transform_straglr_tsv.py --input {input.tsv} --output {output.tsv_t}"

rule select_regions_bam:
	input:
		bam=path+"{sample}/{sample}"+"-dorado.pass.bam",
		bed=nanopath+"bed/{gene}_filter.bed",
	output:
		bam_o=path+"{sample}/nanoexpansion/native{sample}"+"_str_regions.bam"
	message: ">> {wildcards.sample} : selecting regions of interest in bam file"
	shell:
		"samtools view -b -h -o {output.bam_o} -L {input.bed} {input.bam}"

rule index_str_bam:
	input:
		bam=path+"{sample}/nanoexpansion/native{sample}"+"_str_regions.bam"
	output:
		bai=path+"{sample}/nanoexpansion/native{sample}"+"_str_regions.bam.bai"
	shell:
		"samtools index {input.bam}"

rule tail:
	input:
		tsv=path+"{sample}/nanoexpansion/"+"{sample}-straglr.tsv"
	output:
		reads=path+"{sample}/nanoexpansion/"+"{sample}_reads_to_filter.txt"
	shell:
		"tail -n +3 {input.tsv} | cut -f 6 > {output.reads}"

rule select_reads:
	input:
		bam=path+"{sample}/nanoexpansion/native{sample}"+"_str_regions.bam",
		reads=path+"{sample}/nanoexpansion/"+"{sample}_reads_to_filter.txt"
	output:
		bam_o=path+"{sample}/nanoexpansion/native{sample}"+"_str_reads.bam"
	message: ">> {wildcards.sample} : selecting reads of interest in bam file"
	shell:
		"samtools view --write-index -N {input.reads} -o {output.bam_o} {input.bam}"

rule stranger:
	input:
		json=path + "variant_catalog_hg38.json",
		vcf=path+"{sample}/nanoexpansion/"+"{sample}-straglr.vcf"
	output:
		vcf_o=path+"{sample}/nanoexpansion/"+"{sample}_straglr_annot.vcf"
	log:
		"logs/stranger/{sample}.log"
	message: ">> {wildcards.sample} : annotating with stranger"
	shell:
		"stranger -f {input.json} {input.vcf} > {output.vcf_o} | sed 's/\\ / _/g'"

rule bgzip:
	input:
		vcf=path+"{sample}/nanoexpansion/"+"{sample}_straglr_annot.vcf"
	output:
		path+"{sample}/nanoexpansion/"+"{sample}_straglr_annot.vcf.gz"
	shell:
		"bgzip {input.vcf}"

rule tabix:
	input:
		vcf=path+"{sample}/nanoexpansion/"+"{sample}_straglr_annot.vcf.gz"
	output:
		path+"{sample}/nanoexpansion/"+"{sample}_straglr_annot.vcf.gz.csi"
	shell:
		"tabix {input.vcf}"

rule snipsift_annot:
	input:
		vcf=path+"{sample}/nanoexpansion/"+"{sample}_straglr_annot.vcf.gz"
	output:
		tsv=path+"{sample}/nanoexpansion/"+"native{sample}_rep_annot.tsv"
	log:
		"logs/snipsift/{sample}.log"
	message: ">> {wildcards.sample} : snipsift annot"
	shell:
		"SnpSift extractFields {input.vcf} CHROM POS ALT FILTER REF RL RU REPID VARID STR_STATUS > {output.tsv}"

rule snipsift_plot:
	input:
		vcf=path+"{sample}/nanoexpansion/"+"{sample}_straglr_annot.vcf.gz"
	output:
		tsv=path+"{sample}/nanoexpansion/"+"native{sample}_rep_plot.tsv"
	message: ">> {wildcards.sample} : snipsift plot"
	shell:
		"SnpSift extractFields {input.vcf} CHROM POS DisplayRU STR_NORMAL_MAX STR_PATHOLOGIC_MIN VARID Disease > {output.tsv}"

rule nanoexpansion:
	input:
		path=path #+"{sample}/nanoexpansion/"
	output:
		path+"{sample}/nanoexpansion/{sample}_{disease}_{gene}.txt"
	params:
		motif=lambda wildcards: config["motif"],
		interruption=lambda wildcards: config["interruption"],
		ins1=lambda wildcards: config["ins1"],
		ins2=lambda wildcards: config["ins2"]
	log:
		"logs/NanoExpansion/{sample}_{disease}_{gene}.log"
	message: ">> {wildcards.sample} : executing NanoExpansion"
	shell:
		"python NanoExpansion.py --sample {sample} --repeat {params.motif} --interruption {params.interruption} --path {input.path} --ins1 {params.ins1} --ins2 {params.ins2}"
